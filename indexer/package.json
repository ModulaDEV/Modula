{
  "name": "@modula/indexer",
  "version": "0.1.0",
  "description": "viem event listener + Postgres + read API for the Modula protocol.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev":       "tsx watch src/index.ts",
    "start":     "node dist/index.js",
    "build":     "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint":      "eslint src",
    "test":      "vitest run",
    "test:watch":"vitest",
    "migrate":   "node-pg-migrate -m migrations -j sql up"
  },
  "dependencies": {
    "@modula/abi": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono":  "^4.6.0",
    "node-pg-migrate": "^7.6.0",
    "pg":    "^8.13.0",
    "pino":  "^9.4.0",
    "pino-pretty": "^11.0.0",
    "viem":  "^2.21.0",
    "zod":   "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.0",
    "@types/node": "^20.0.0",
    "@types/pg":   "^8.11.0",
    "tsx":         "^4.21.0",
    "typescript":  "^5.6.0",
    "vitest":      "^2.1.0"
  }
}
