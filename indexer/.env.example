# --- chain ---
CHAIN=baseSepolia
BASE_RPC_URL=https://sepolia.base.org

# Override the addresses in @modula/abi when running against a local
# Anvil fork — leave unset to use the canonical addresses for CHAIN.
# REGISTRY_ADDRESS=
# ACCESS_ROUTER_ADDRESS=

# --- database ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
DATABASE_POOL_MAX=10

# --- listener ---
START_BLOCK=0
POLL_INTERVAL_MS=2000
CONFIRMATIONS=0

# --- SVM event source (Solana settlement indexing) ---
# Disabled by default. When enabled, the indexer polls the configured
# Solana cluster for SPL USDC transfers to known model treasury ATAs
# and writes them to svm_calls. The existing EVM listener loop runs
# unchanged regardless.
SVM_ENABLED=false
SVM_NETWORK=solana-devnet
SVM_RPC_URL=
SVM_POLL_INTERVAL_MS=5000

# --- server ---
PORT=8788
HOST=0.0.0.0

# --- observability ---
LOG_LEVEL=info
NODE_ENV=production
