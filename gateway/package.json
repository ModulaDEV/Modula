{
  "name": "@modula/gateway",
  "version": "0.1.0",
  "description": "MCP gateway + x402 payment middleware for the Modula protocol.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev":       "tsx watch src/server.ts",
    "start":     "node dist/server.js",
    "build":     "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint":      "eslint src",
    "test":      "vitest run",
    "test:watch":"vitest"
  },
  "dependencies": {
    "@modula/abi": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "hono":  "^4.6.0",
    "jose":  "^5.9.0",
    "pino":  "^9.4.0",
    "pino-pretty": "^11.0.0",
    "viem":  "^2.21.0",
    "zod":   "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx":         "^4.21.0",
    "typescript":  "^5.6.0",
    "vitest":      "^2.1.0"
  }
}
