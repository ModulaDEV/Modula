# --- Modula Gateway ---

# HTTP listener
PORT=8787
HOST=0.0.0.0

# Chain
CHAIN=base                    # base | baseSepolia
BASE_RPC_URL=https://mainnet.base.org

# Modula contracts on the active chain (read from @modula/abi/addresses by default;
# set these to override for local Anvil testing)
REGISTRY_ADDRESS=
ACCESS_ROUTER_ADDRESS=

# Gateway hot-wallet (writes ModelCalled events; rotate frequently)
GATEWAY_SIGNER_PRIVATE_KEY=

# x402 facilitator
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/x402
X402_FACILITATOR_API_KEY=

# OAuth 2.1 (per MCP 2025-11-25 spec). Disabled by default for dev;
# turn on in prod with an OIDC issuer (Clerk, Auth0, WorkOS, custom).
OAUTH_ENABLED=false
OAUTH_ISSUER=                 # e.g. https://clerk.modula.com
OAUTH_AUDIENCE=               # e.g. modula-mcp-gateway
OAUTH_JWKS_URI=               # optional override; defaults to ${OAUTH_ISSUER}/.well-known/jwks.json
OAUTH_RESOURCE=               # optional, public URL of this gateway (e.g. https://mcp.modulabase.org)

# Operational
LOG_LEVEL=info                # trace | debug | info | warn | error
NODE_ENV=production
