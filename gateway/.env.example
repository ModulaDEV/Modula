# --- Modula Gateway ---

# HTTP listener
PORT=8787
HOST=0.0.0.0

# Chain
CHAIN=base                    # base | baseSepolia
BASE_RPC_URL=https://mainnet.base.org

# Modula contracts on the active chain (read from @modula/abi/addresses by default;
# set these to override for local Anvil testing)
REGISTRY_ADDRESS=
ACCESS_ROUTER_ADDRESS=

# Gateway hot-wallet (writes ModelCalled events; rotate frequently)
GATEWAY_SIGNER_PRIVATE_KEY=

# x402 facilitator. Default is the public, unauthenticated x402.org
# facilitator (no API key needed). Override with a managed facilitator
# (Coinbase CDP, self-hosted, etc.) by setting both URL and API_KEY.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_FACILITATOR_API_KEY=

# --- Solana settlement (SVM x402 path) ---
# Disabled by default. When enabled, the gateway mounts
# POST /m/:agency/mcp/svm and accepts USDC payments on Solana.
# All other SVM_* values are ignored when SVM_ENABLED=false.
SVM_ENABLED=false
SVM_NETWORK=solana-devnet      # solana | solana-devnet
SVM_RPC_URL=                   # e.g. https://api.devnet.solana.com (paid RPC strongly preferred for prod)
SVM_X402_FACILITATOR_URL=      # required when SVM_ENABLED=true — gateway boot fails loud otherwise
SVM_X402_FACILITATOR_API_KEY=  # bearer for managed SVM facilitators (Helius, Triton)

# OAuth 2.1 (per MCP 2025-11-25 spec). Disabled by default for dev;
# turn on in prod with an OIDC issuer (Clerk, Auth0, WorkOS, custom).
OAUTH_ENABLED=false
OAUTH_ISSUER=                 # e.g. https://clerk.modula.com
OAUTH_AUDIENCE=               # e.g. modula-mcp-gateway
OAUTH_JWKS_URI=               # optional override; defaults to ${OAUTH_ISSUER}/.well-known/jwks.json
OAUTH_RESOURCE=               # optional, public URL of this gateway (e.g. https://mcp.modulabase.org)

# Operational
LOG_LEVEL=info                # trace | debug | info | warn | error
NODE_ENV=production
