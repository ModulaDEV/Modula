# Modula landing site environment
#
# Currently the site is fully static — no environment variables are
# required. This file exists so future integrations (analytics,
# on-chain RPC, indexer API) can be plugged in without a schema
# surprise.

# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://modula.base

# --- Future integrations (not yet used) ---
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
# NEXT_PUBLIC_REGISTRY_INDEXER=https://indexer.modula.base
# NEXT_PUBLIC_X402_GATEWAY=https://mcp.modula.base
