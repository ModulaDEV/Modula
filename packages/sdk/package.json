{
  "name": "@modula/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Modula protocol — discover, read, and call on-chain AI models from your agent.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean":     "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript":  "^5.6.0"
  }
}
